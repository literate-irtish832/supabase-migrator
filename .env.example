# ─────────────────────────────────────────────────────────────
# Supabase Migration Tool -Environment Configuration
# ─────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# Where to find these values:
#
#   DATABASE URL (SOURCE_DB_URL / DEST_DB_URL):
#     Dashboard > Project Settings > Database > Connection string > URI
#     Use the "direct" connection (port 5432), NOT the pooler.
#     The password is the one you set when creating the project.
#
#   PROJECT REF (SOURCE_PROJECT_REF / DEST_PROJECT_REF):
#     Dashboard > Project Settings > General > Reference ID
#     Also visible in your project URL: https://<ref>.supabase.co
#
#   SERVICE ROLE KEY (SOURCE_SERVICE_ROLE_KEY / DEST_SERVICE_ROLE_KEY):
#     Dashboard > Project Settings > API > service_role (secret)
#     ⚠️  This key bypasses RLS -never expose it in client code.
#
#   PROJECT URL (SOURCE_PROJECT_URL / DEST_PROJECT_URL):
#     Dashboard > Project Settings > API > Project URL
#     Format: https://<project-ref>.supabase.co
#
# ─────────────────────────────────────────────────────────────

# Source Supabase Project
SOURCE_DB_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
SOURCE_PROJECT_REF="your-source-project-ref"
SOURCE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SOURCE_PROJECT_URL="https://your-source-project-ref.supabase.co"

# Destination Supabase Project
DEST_DB_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DEST_PROJECT_REF="your-dest-project-ref"
DEST_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
DEST_PROJECT_URL="https://your-dest-project-ref.supabase.co"
